      "text": false,
      "palette": [
        {
          "slug": "heading",
          "color": "#061125",
          "name": "Heading"
        },
        {
          "slug": "accent-muted",
          "color": "#92a8cc",
          "name": "Accent muted"
        }
      ]
    },
    "custom": {
      "spacing": {},
      "typography": {
        "font-size": {},
        "line-height": {}
      }
    },
    "spacing": {
